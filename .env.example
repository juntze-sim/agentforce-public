# AgentForce — environment configuration
# Copy this file to .env and fill in values as needed.
# This project runs fully locally via Ollama — no cloud API keys are required
# by default. The variables below let you override defaults or add integrations.

# ---------------------------------------------------------------------------
# Ollama (required — install from https://ollama.com)
# ---------------------------------------------------------------------------

# Base URL of your Ollama instance (default: http://localhost:11434)
OLLAMA_BASE_URL=

# Model to use for all agents (default: qwen3:8b)
# Run `ollama pull <model>` to download before first use.
OLLAMA_MODEL=

# ---------------------------------------------------------------------------
# Optional: swap to a cloud LLM provider
# Uncomment and populate if you replace ChatOllama with a cloud-based client.
# ---------------------------------------------------------------------------

# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
